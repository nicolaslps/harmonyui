<div class="my-8">
    <h2 class="text-lg font-semibold text-gray-900 mb-4">Props</h2>
    <twig:ui:Table>
        <twig:ui:Table:Header>
            <twig:ui:Table:Row>
                <twig:ui:Table:Head>Prop</twig:ui:Table:Head>
                <twig:ui:Table:Head>Default</twig:ui:Table:Head>
                <twig:ui:Table:Head>Description</twig:ui:Table:Head>
            </twig:ui:Table:Row>
        </twig:ui:Table:Header>
        <twig:ui:Table:Body>
            {% for prop in props %}
                <twig:ui:Table:Row>
                    <twig:ui:Table:Cell>
                        <code class="text-sm font-mono bg-muted text-foreground px-1.5 py-0.5 rounded">{{ prop.name }}</code>
                    </twig:ui:Table:Cell>
                    <twig:ui:Table:Cell>
                        {% if prop.default is defined and prop.default is not null %}
                            <code class="text-sm font-mono bg-muted text-foreground px-1.5 py-0.5 rounded">{{ prop.default }}</code>
                        {% else %}
                            <span class="text-sm text-muted-foreground">—</span>
                        {% endif %}
                    </twig:ui:Table:Cell>
                    <twig:ui:Table:Cell class="text-sm">{{ prop.description }}</twig:ui:Table:Cell>
                </twig:ui:Table:Row>
            {% endfor %}
        </twig:ui:Table:Body>
    </twig:ui:Table>
</div>
